{
    "name": "mrmat-versioning-action",
    "description": "A GitHub Action to create a unique project versions",
    "version": "0.0.0",
    "author": "MrMat",
    "license": "MIT",
    "type": "module",
    "private": true,
    "homepage": "https://github.com/MrMatAP/mrmat-versioning-action",
    "repository": {
        "type": "git",
        "url": "https://github.com//MrMatAP/mrmat-versioning-action.git"
    },
    "bugs": {
        "url": "https://github.com//MrMatAP/mrmat-versioning-action/issues"
    },
    "keywords": [
        "actions"
    ],
    "exports": {
        ".": "./dist/index.js"
    },
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "bundle": "npm run format:write && npm run package",
        "format:write": "npx prettier --write .",
        "format:check": "npx prettier --check .",
        "ci-lint": "npx eslint .",
        "lint": "npx eslint .",
        "package": "npx rollup --config rollup.config.js --configPlugin @rollup/plugin-typescript",
        "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
        "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest"
    },
    "dependencies": {
        "@actions/core": "^1.11.1",
        "@actions/github": "^9.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@github/local-action": "^3.2.0",
        "@jest/globals": "^30.1.2",
        "@rollup/plugin-commonjs": "^28.0.6",
        "@rollup/plugin-node-resolve": "^16.0.1",
        "@rollup/plugin-typescript": "^12.1.4",
        "@stylistic/eslint-plugin": "^5.4.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.3.1",
        "eslint": "^9.39.1",
        "jest": "^30.1.3",
        "jest-junit": "^16.0.0",
        "jiti": "^2.6.1",
        "prettier": "^3.6.2",
        "prettier-eslint": "^16.3.0",
        "rollup": "4.59.0",
        "ts-jest": "^29.4.1",
        "ts-jest-resolver": "^2.0.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.46.4"
    }
}
